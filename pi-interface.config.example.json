{
  "cwd": "./workspace",
  "agentDir": "./.pi-interface-agent",
  "sandbox": {
    "root": "./workspace",
    "allowWrite": true,
    "writableRoot": "./workspace/scratch",
    "allowBash": false
  },
  "noExtensions": true,
  "extensionPaths": [],
  "server": {
    "port": 3141,
    "host": "127.0.0.1",
    "allowedOrigins": ["https://app.example.com"]
  },
  "branding": {
    "title": "My Assistant",
    "welcome": "Ask anything about the project.",
    "accentColor": "#0ea5e9",
    "defaultTheme": "system",
    "allowThemeToggle": true
  }
}
