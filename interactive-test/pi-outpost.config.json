{
  "cwd": "./workspace",
  "agentDir": "./.pi-agent",
  "sandbox": {
    "root": "./workspace",
    "allowWrite": true,
    "writableRoot": "./workspace",
    "allowBash": false
  },
  "sandboxLocks": {
    "allowBash": true
  },
  "noExtensions": true,
  "extensionPaths": ["./mon-ext/index.ts"],
  "noSkills": false,
  "skillPaths": ["./skills"],
  "noPromptTemplates": true,
  "webContext": false,
  "server": {
    "port": 3142,
    "host": "127.0.0.1"
  },
  "branding": {
    "title": "Pi-Outpost Demo",
    "welcome": "Extension demo with extensionScripts 👋",
    "accentColor": "#0ea5e9"
  }
}
