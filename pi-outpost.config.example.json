{
  "cwd": "./workspace",
  "agentDir": "./.pi-outpost-agent",
  "sandbox": {
    "root": "./workspace",
    "allowWrite": true,
    "writableRoot": "./workspace/scratch",
    "allowBash": false
  },
  "noExtensions": true,
  "extensionPaths": [],
  "extensionScripts": [],
  "noSkills": true,
  "skillPaths": [],
  "noPromptTemplates": true,
  "promptPaths": ["./my-prompts"],
  "webContext": true,
  "allowedModels": [{ "provider": "anthropic", "id": "claude-sonnet-5" }],
  "appendSystemPrompt": ["Only discuss topics related to this project."],
  "server": {
    "port": 3141,
    "host": "127.0.0.1",
    "allowedOrigins": ["https://app.example.com"],
    "token": "replace-with-long-random-secret-or-use-PI_OUTPOST_TOKEN"
  },
  "branding": {
    "title": "My Assistant",
    "welcome": "Ask anything about the project.",
    "accentColor": "#0ea5e9",
    "defaultTheme": "system",
    "allowThemeToggle": true
  }
}
